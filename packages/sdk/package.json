{
	"name": "@juliusbrussee/caveman-sdk",
	"version": "0.65.2",
	"description": "TypeScript SDK for the caveman-code daemon HTTP + WebSocket API. Generated from openapi.yaml.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"keywords": [
		"caveman-code",
		"sdk",
		"daemon",
		"openapi",
		"typescript"
	],
	"author": "Julius Brussee",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JuliusBrussee/caveman-code.git",
		"directory": "packages/sdk"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@types/ws": "^8.5.13",
		"shx": "^0.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"homepage": "https://github.com/JuliusBrussee/caveman-code#readme",
	"bugs": {
		"url": "https://github.com/JuliusBrussee/caveman-code/issues"
	},
	"publishConfig": {
		"access": "public"
	}
}
