{
	"name": "@juliusbrussee/caveman-pods",
	"version": "0.65.2",
	"description": "CLI tool for managing vLLM deployments on GPU pods",
	"type": "module",
	"bin": {
		"cave-pods": "dist/cli.js"
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js && shx cp src/models.json dist/ && shx cp -r scripts dist/",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist",
		"scripts"
	],
	"keywords": [
		"llm",
		"vllm",
		"gpu",
		"ai",
		"cli"
	],
	"author": "Julius Brussee",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JuliusBrussee/caveman-cli.git",
		"directory": "packages/pods"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@juliusbrussee/caveman-agent": "^0.65.2",
		"chalk": "^5.5.0"
	},
	"devDependencies": {},
	"homepage": "https://github.com/JuliusBrussee/caveman-cli#readme",
	"bugs": {
		"url": "https://github.com/JuliusBrussee/caveman-cli/issues"
	},
	"publishConfig": {
		"access": "public"
	}
}
