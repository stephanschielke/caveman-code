{
	"name": "@juliusbrussee/caveman-markdown-preview",
	"version": "0.9.6",
	"description": "Rendered markdown + LaTeX preview for caveman-code, with terminal, browser, and PDF output",
	"type": "module",
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"license": "MIT",
	"keywords": [
		"pi-package",
		"caveman-code",
		"markdown",
		"preview"
	],
	"files": [
		"index.ts",
		"client",
		"shared",
		"tsconfig.json",
		"README.md"
	],
	"scripts": {
		"clean": "echo \"no build artifacts to clean\"",
		"build": "echo \"no build step — ships .ts source as extension\""
	},
	"peerDependencies": {
		"@juliusbrussee/caveman-code": "*",
		"@juliusbrussee/caveman-tui": "*"
	},
	"dependencies": {
		"puppeteer-core": "^24.22.3"
	},
	"devDependencies": {
		"@juliusbrussee/caveman-code": "*",
		"@juliusbrussee/caveman-tui": "*",
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JuliusBrussee/caveman-cli.git",
		"directory": "packages/markdown-preview"
	},
	"homepage": "https://github.com/JuliusBrussee/caveman-cli#readme",
	"bugs": {
		"url": "https://github.com/JuliusBrussee/caveman-cli/issues"
	},
	"author": "Julius Brussee",
	"publishConfig": {
		"access": "public"
	}
